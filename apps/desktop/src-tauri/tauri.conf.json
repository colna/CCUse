{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CCUse",
  "version": "1.0.1",
  "identifier": "io.ccuse.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CCUse",
        "width": 1024,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* https://api.openai.com https://api.anthropic.com https://generativelanguage.googleapis.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:"
    },
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": false
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "category": "DeveloperTool",
    "publisher": "CCUse Contributors",
    "homepage": "https://github.com/colna/CCUse",
    "copyright": "© 2026 CCUse Contributors",
    "shortDescription": "本地 API 代理 + 多供应商无感切换",
    "longDescription": "CCUse 在本地启动统一的 API 代理服务，将多个 AI 供应商抽象为单一接口；后台健康检查 + 自动故障转移，对客户端完全无感。",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
