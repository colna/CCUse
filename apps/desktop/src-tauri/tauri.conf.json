{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CCUse",
  "version": "0.0.0",
  "identifier": "io.ccuse.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CCUse",
        "width": 1024,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "category": "DeveloperTool",
    "shortDescription": "本地 API 代理 + 多供应商无感切换",
    "longDescription": "CCUse 在本地启动统一的 API 代理服务，将多个 AI 供应商抽象为单一接口；后台健康检查 + 自动故障转移，对客户端完全无感。",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}
