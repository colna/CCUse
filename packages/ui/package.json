{
  "name": "@ccuse/ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "types": "./index.ts",
  "scripts": {
    "test": "node scripts/verify-shadcn-layer.mjs",
    "lint": "pnpm --dir ../.. exec eslint packages/ui",
    "lint:fix": "pnpm --dir ../.. exec eslint packages/ui --fix",
