{
  "name": "ccuse",
  "version": "0.0.0",
  "private": true,
  "description": "CCUse - 本地 API 代理 + 多供应商无感切换",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev:desktop": "turbo run tauri:dev --filter=@ccuse/desktop",
    "dev:website": "turbo run dev --filter=@ccuse/website",
    "build": "turbo run build",
    "build:desktop": "turbo run tauri:build --filter=@ccuse/desktop",
    "build:website": "turbo run build --filter=@ccuse/website",
    "test": "turbo run test",
    "test:desktop": "turbo run test --filter=@ccuse/desktop",
    "test:website": "turbo run test --filter=@ccuse/website",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "verify-turbo": "node scripts/verify-phase-1-0-w-turbo.mjs",
    "website:verify-lint": "node scripts/verify-phase-1-0-w-lint.mjs",
    "website:verify-workspace": "node scripts/verify-phase-1-0-w-workspace.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.9.12",
    "typescript-eslint": "^8.59.1"
  },
  "lint-staged": {
    "{apps/desktop,apps/website,packages/ui}/**/*.{ts,tsx,js,mjs}": [
      "pnpm exec eslint --fix",
      "prettier --write"
    ],
    "{apps/desktop,apps/website,packages/ui}/**/*.{css,json,md}": [
      "prettier --write"
    ],
    "apps/desktop/src-tauri/**/*.rs": [
      "bash -c 'cd apps/desktop/src-tauri && cargo fmt -- --check'"
    ],
    "*.{md,json,yaml,yml}": [
      "prettier --write"
    ]
  }
}
