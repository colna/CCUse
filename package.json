{
  "name": "ccuse",
  "version": "0.0.0",
  "private": true,
  "description": "CCUse - 本地 API 代理 + 多供应商无感切换",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "desktop:dev": "pnpm --filter @ccuse/desktop tauri dev",
    "desktop:build": "pnpm --filter @ccuse/desktop tauri build",
    "desktop:test": "pnpm --filter @ccuse/desktop test",
    "desktop:typecheck": "pnpm --filter @ccuse/desktop typecheck",
    "website:verify-workspace": "node scripts/verify-phase-1-0-w-workspace.mjs",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.6.14"
  },
  "lint-staged": {
    "apps/desktop/**/*.{ts,tsx}": [
      "pnpm --filter @ccuse/desktop exec eslint --fix",
      "prettier --write"
    ],
    "apps/desktop/**/*.{css,json,md}": [
      "prettier --write"
    ],
    "apps/desktop/src-tauri/**/*.rs": [
      "bash -c 'cd apps/desktop/src-tauri && cargo fmt -- --check'"
    ],
    "*.{md,json,yaml,yml}": [
      "prettier --write"
    ]
  }
}
